{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Implementation-ready, token-driven UI guidance for Moderno — the ui design stack for modern founders — optimized for consistency, accessibility, and fast delivery products.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.98, 0.98, 0.98],
        "hex": "#fafafa"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.094, 0.094, 0.106],
        "hex": "#18181b"
      }
    },
    "text-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.98, 0.98, 0.98],
        "hex": "#fafafa"
      }
    },
    "text-secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.38, 0.38, 0.38],
        "hex": "#616161"
      }
    },
    "text-tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.071, 0.071, 0.071],
        "hex": "#121212"
      }
    },
    "text-inverse": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.094, 0.094, 0.106],
        "hex": "#18181b"
      }
    },
    "surface-base": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.051, 0.051, 0.051],
        "hex": "#0d0d0d"
      }
    },
    "surface-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "hex": "#000000"
      }
    },
    "border-default": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.11, 0.11, 0.11],
        "hex": "#1c1c1c"
      }
    }
  },
  "spacing": {
    "1": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "2": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "3": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "4": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "5": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "6": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "7": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "8": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "$type": "dimension"
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 96,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        },
        "lineHeight": 104
      }
    },
    "headline-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 24,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 32
      }
    },
    "headline-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 20,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 28
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 18,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 28
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 24
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 14,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 20
      }
    },
    "label-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 16
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Hedvig Letters Sans",
        "fontSize": {
          "value": 10,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 14
      }
    }
  }
}
