{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "theme-contrast — a synthetic maximum-contrast brand used to demonstrate the multi-brand switch. Scoped under [data-brand=\"contrast\"], composed with .dark. Pure black/white pairs (21:1) by design.",
  "$extensions": {
    "style.moderno.theme": {
      "name": "theme-contrast",
      "brand": "contrast"
    }
  },
  "light": {
    "background": { "$type": "color", "$value": "oklch(1 0 0)" },
    "foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "card": { "$type": "color", "$value": "oklch(1 0 0)" },
    "card-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "popover": { "$type": "color", "$value": "oklch(1 0 0)" },
    "popover-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "primary": { "$type": "color", "$value": "oklch(0 0 0)" },
    "primary-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "secondary": { "$type": "color", "$value": "oklch(1 0 0)" },
    "secondary-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "muted": { "$type": "color", "$value": "oklch(1 0 0)" },
    "muted-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "accent": { "$type": "color", "$value": "oklch(0 0 0)" },
    "accent-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "destructive": { "$type": "color", "$value": "oklch(0.45 0.3 27)" },
    "destructive-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "border": { "$type": "color", "$value": "oklch(0 0 0)" },
    "input": { "$type": "color", "$value": "oklch(0 0 0)" },
    "ring": { "$type": "color", "$value": "oklch(0 0 0)" },
    "chart-1": { "$type": "color", "$value": "oklch(0 0 0)" },
    "chart-2": { "$type": "color", "$value": "oklch(0.3 0 0)" },
    "chart-3": { "$type": "color", "$value": "oklch(0.5 0 0)" },
    "chart-4": { "$type": "color", "$value": "oklch(0.45 0.3 27)" },
    "chart-5": { "$type": "color", "$value": "oklch(0.45 0.25 264)" },
    "radius": { "$type": "dimension", "$value": "0rem" },
    "font-sans": {
      "$type": "fontFamily",
      "$value": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", sans-serif"
    },
    "font-mono": {
      "$type": "fontFamily",
      "$value": "ui-monospace, \"SFMono-Regular\", \"Menlo\", \"Consolas\", monospace"
    }
  },
  "dark": {
    "background": { "$type": "color", "$value": "oklch(0 0 0)" },
    "foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "card": { "$type": "color", "$value": "oklch(0 0 0)" },
    "card-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "popover": { "$type": "color", "$value": "oklch(0 0 0)" },
    "popover-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "primary": { "$type": "color", "$value": "oklch(1 0 0)" },
    "primary-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "secondary": { "$type": "color", "$value": "oklch(0 0 0)" },
    "secondary-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "muted": { "$type": "color", "$value": "oklch(0 0 0)" },
    "muted-foreground": { "$type": "color", "$value": "oklch(1 0 0)" },
    "accent": { "$type": "color", "$value": "oklch(1 0 0)" },
    "accent-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "destructive": { "$type": "color", "$value": "oklch(0.7 0.25 27)" },
    "destructive-foreground": { "$type": "color", "$value": "oklch(0 0 0)" },
    "border": { "$type": "color", "$value": "oklch(1 0 0)" },
    "input": { "$type": "color", "$value": "oklch(1 0 0)" },
    "ring": { "$type": "color", "$value": "oklch(1 0 0)" },
    "chart-1": { "$type": "color", "$value": "oklch(1 0 0)" },
    "chart-2": { "$type": "color", "$value": "oklch(0.8 0 0)" },
    "chart-3": { "$type": "color", "$value": "oklch(0.6 0 0)" },
    "chart-4": { "$type": "color", "$value": "oklch(0.7 0.25 27)" },
    "chart-5": { "$type": "color", "$value": "oklch(0.7 0.2 264)" },
    "radius": { "$type": "dimension", "$value": "0rem" },
    "font-sans": {
      "$type": "fontFamily",
      "$value": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", sans-serif"
    },
    "font-mono": {
      "$type": "fontFamily",
      "$value": "ui-monospace, \"SFMono-Regular\", \"Menlo\", \"Consolas\", monospace"
    }
  }
}
