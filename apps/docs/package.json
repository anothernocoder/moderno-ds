{
  "name": "@moderno/docs",
  "version": "0.0.0",
  "description": "Moderno docs — flat Astro + MDX + Content Collections, bilingual en/es, Svelte islands for live previews, autogenerated PropsTable, Theme Builder, and the static registry served under /r/.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node --experimental-strip-types ../../tooling/props-doc/src/bin.ts && node --experimental-strip-types ./scripts/copy-registry.ts",
    "dev": "pnpm run prebuild && astro dev",
    "build": "pnpm run prebuild && astro build && pnpm run index",
    "index": "pagefind --site dist/en --output-path dist/en/pagefind && pagefind --site dist/es --output-path dist/es/pagefind",
    "preview": "astro preview",
    "typecheck": "astro check",
    "check:parity": "node --experimental-strip-types ./scripts/check-parity.ts"
  },
  "dependencies": {
    "@moderno/charts-core": "workspace:*",
    "@moderno/core": "workspace:*",
    "@moderno/css": "workspace:*",
    "@moderno/svelte": "workspace:*",
    "@moderno/theme-compile": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/svelte": "^7.0.9",
    "@astrojs/vercel": "^8.1.0",
    "@moderno/props-doc": "workspace:*",
    "astro": "^5.13.0",
    "pagefind": "^1.3.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.2"
  }
}
