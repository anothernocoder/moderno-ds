---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CopyMarkdown from "../../components/CopyMarkdown.astro";
import { splitId, type Locale } from "../../i18n/ui.ts";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs
    .map((entry) => ({ entry, ...splitId(entry.id) }))
    .filter((p) => p.slug !== "index")
    .map((p) => ({ params: { lang: p.locale, slug: p.slug }, props: { entry: p.entry } }));
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Locale;
const { slug } = splitId(entry.id);
const { Content } = await render(entry);
---

<BaseLayout
  locale={lang}
  title={entry.data.title}
  description={entry.data.description}
  slug={slug}
>
  <h1>{entry.data.title}</h1>
  <p class="page-lead">{entry.data.description}</p>
  <CopyMarkdown />
  <Content />
</BaseLayout>
