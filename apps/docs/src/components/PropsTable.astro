---
import { currentLocale, useTranslations } from "../i18n/ui.ts";

/** Shape of a generated `props/<name>.json` (mirrors @moderno/props-doc). */
interface PropDoc {
  name: string;
  type: string;
  required: boolean;
  default?: string;
  description?: string;
}
interface ComponentDoc {
  name: string;
  props: PropDoc[];
}

interface Props {
  /** Component name matching a generated `props/<name>.json`. */
  component: string;
}

const { component } = Astro.props;
const t = useTranslations(currentLocale(Astro.currentLocale));

// Generated at build by `moderno-props-doc` (the prebuild step). Loaded eagerly
// so a missing component surfaces as a clear build-time error, not a 404.
const modules = import.meta.glob<ComponentDoc>("../generated/props/*.json", { eager: true });
const entry = Object.entries(modules).find(([path]) => path.endsWith(`/${component}.json`));
const doc = entry?.[1] as ComponentDoc | undefined;
const props = doc?.props ?? [];
---

{
  props.length === 0 ? (
    <p class="props-empty">{t("props.empty")}</p>
  ) : (
    <div class="props-table-wrap">
      <table class="props-table">
        <thead>
          <tr>
            <th>{t("props.name")}</th>
            <th>{t("props.type")}</th>
            <th>{t("props.required")}</th>
            <th>{t("props.default")}</th>
            {props.some((p) => p.description) && <th>{t("props.description")}</th>}
          </tr>
        </thead>
        <tbody>
          {props.map((p) => (
            <tr>
              <td>
                <code>{p.name}</code>
              </td>
              <td>
                <code class="props-type">{p.type}</code>
              </td>
              <td>{p.required ? t("props.yes") : t("props.no")}</td>
              <td>{p.default ? <code>{p.default}</code> : "—"}</td>
              {props.some((q) => q.description) && <td>{p.description ?? ""}</td>}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )
}
