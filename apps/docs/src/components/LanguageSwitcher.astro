---
import { locales, useTranslations, type Locale } from "../i18n/ui.ts";

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const t = useTranslations(locale);
const other = locales.find((l) => l !== locale)!;
const path = slug === "index" ? "" : slug;
---

<a class="lang-switch" href={`/${other}/${path}`} hreflang={other} lang={other}>
  {t("lang.switch")}
</a>
