{
  "name": "@moderno/solid",
  "version": "0.0.0",
  "description": "Solid bindings for Moderno: Ark UI headless behaviour + @moderno/core CVA (props → data-attributes), styled entirely by the shared components.css.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.tsx",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@moderno/core": "workspace:*"
  },
  "peerDependencies": {
    "@moderno/css": "workspace:*",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.6.1",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.13",
    "tsup": "^8.3.5",
    "vite-plugin-solid": "^2.11.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
