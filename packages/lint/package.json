{
  "name": "@moderno/lint",
  "version": "0.0.0",
  "description": "ESLint plugin + CLI over @moderno/lint-core's shared rule engine — the same hardcoded-color/prop-validity/raw-Ark/data-part/reimplemented-primitive checks validate_usage runs, for human contributors and CI.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "moderno-lint": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@moderno/lint-core": "workspace:*"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
