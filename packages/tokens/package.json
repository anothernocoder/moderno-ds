{
  "name": "@moderno/tokens",
  "version": "0.0.0",
  "description": "Shadcn-style semantic token contract with neutral OKLCH defaults and a Tailwind v4 preset. Contains no brand identity.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    "./css": "./src/tokens.css",
    "./preset": "./src/preset.css",
    "./contract": "./src/contract.ts",
    "./moderno.agent.json": "./dist/moderno.agent.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node --experimental-strip-types ../../tooling/props-doc/src/bin-agent-manifest.ts tokens"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
