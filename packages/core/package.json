{
  "name": "@moderno/core",
  "version": "0.0.0",
  "description": "Framework-agnostic core: CVA (props → deterministic data-attributes), class utils, and the shared components.css skeleton on [data-scope]/[data-part].",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/components.css": "./src/styles/components.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
