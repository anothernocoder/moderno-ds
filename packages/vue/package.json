{
  "name": "@moderno/vue",
  "version": "0.0.0",
  "description": "Vue 3 bindings for Moderno: Ark UI headless behaviour + @moderno/core CVA (props → data-attributes), styled entirely by the shared components.css.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/vue": "^5.37.2",
    "@moderno/core": "workspace:*"
  },
  "peerDependencies": {
    "@moderno/css": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vue/server-renderer": "^3.5.38",
    "tsup": "^8.3.5",
    "vue": "^3.5.38",
    "vue-tsc": "^2.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
