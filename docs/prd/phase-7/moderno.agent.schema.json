{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://moderno.style/schema/moderno.agent.json",
  "title": "Moderno agent manifest",
  "description": "Per-package manifest emitted to dist as moderno.agent.json. @moderno/mcp aggregates these from the consumer's node_modules at startup so answers are pinned to the installed version. Component packages emit kind='components'; @moderno/tokens emits kind='contract' (shared, framework-agnostic).",
  "type": "object",
  "oneOf": [
    { "$ref": "#/definitions/componentsManifest" },
    { "$ref": "#/definitions/contractManifest" }
  ],
  "definitions": {
    "componentsManifest": {
      "type": "object",
      "required": ["package", "version", "kind", "framework", "components"],
      "additionalProperties": false,
      "properties": {
        "package": { "type": "string", "examples": ["@moderno/react"] },
        "version": { "type": "string", "description": "Package version; the MCP reports the API for THIS version." },
        "kind": { "const": "components" },
        "framework": { "enum": ["react", "vue", "svelte", "solid", "astro"] },
        "generatedFrom": {
          "type": "object",
          "description": "Provenance, for the CI drift gate.",
          "properties": {
            "propsDoc": { "type": "boolean" },
            "mdxAgentBlock": { "type": "boolean" }
          }
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/component" }
        }
      }
    },
    "component": {
      "type": "object",
      "required": ["name", "scope", "import", "props", "parts"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "Display/API name, e.g. Button.", "examples": ["Button"] },
        "scope": { "type": "string", "description": "data-scope value; the styling anchor.", "examples": ["button", "dialog"] },
        "import": { "type": "string", "description": "Copy-paste import for this framework.", "examples": ["import { Button } from \"@moderno/react\""] },
        "propsHash": { "type": "string", "description": "Hash of generated props; the CI gate compares against the agent: block's recorded hash to detect staleness." },
        "props": {
          "type": "array",
          "description": "Generated by props-doc (workspace-origin props only, no inherited DOM attrs).",
          "items": { "$ref": "#/definitions/prop" }
        },
        "parts": {
          "type": "array",
          "description": "data-part vocabulary for this scope. Overriding CSS may only target these parts.",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "examples": ["root", "content", "trigger"] },
              "description": { "type": "string" }
            }
          }
        },
        "variants": {
          "type": "object",
          "description": "data-variant / data-size etc. resolved from props by CVA. Keys are the attribute stem; values are the allowed enum. validate_usage checks values against these.",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "code"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "code": { "type": "string", "description": "Framework-specific snippet." }
            }
          }
        },
        "guidance": { "$ref": "#/definitions/guidance" }
      }
    },
    "prop": {
      "type": "object",
      "required": ["name", "type", "required"],
      "additionalProperties": false,
      "description": "Mirrors props-doc PropDoc exactly.",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "description": "Resolved TS type, formatted for display." },
        "required": { "type": "boolean" },
        "default": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "guidance": {
      "type": "object",
      "description": "Curated layer from the docs MDX agent: front-matter block. The judgment an agent needs to pick the RIGHT primitive, not just call it right.",
      "additionalProperties": false,
      "properties": {
        "intent": { "type": "string", "description": "One line: what this primitive is for." },
        "whenToUse": { "type": "string" },
        "whenNotToUse": {
          "type": "array",
          "description": "Steer to the correct alternative.",
          "items": {
            "type": "object",
            "required": ["case", "use"],
            "additionalProperties": false,
            "properties": {
              "case": { "type": "string", "description": "The situation." },
              "use": { "type": "string", "description": "The primitive to reach for instead." }
            }
          }
        },
        "gotchas": { "type": "array", "items": { "type": "string" } },
        "theming": { "type": "array", "items": { "type": "string" }, "description": "Slot/data-part notes specific to this component." }
      }
    },
    "contractManifest": {
      "type": "object",
      "description": "Shared, framework-agnostic contract. Ships in @moderno/tokens. Backs get_contract and feeds the token-related validate rules.",
      "required": ["package", "version", "kind", "goldenRule", "slots", "rules"],
      "additionalProperties": false,
      "properties": {
        "package": { "const": "@moderno/tokens" },
        "version": { "type": "string" },
        "kind": { "const": "contract" },
        "goldenRule": { "type": "string" },
        "slots": {
          "type": "object",
          "description": "The only values components may reference. validate_usage's no-hardcoded-* rules consult these.",
          "additionalProperties": false,
          "properties": {
            "color": { "type": "array", "items": { "type": "string" } },
            "radius": { "type": "array", "items": { "type": "string" } },
            "font": { "type": "array", "items": { "type": "string" } },
            "spacing": { "type": "array", "items": { "type": "string" } },
            "motion": { "type": "array", "items": { "type": "string" } }
          }
        },
        "theming": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "darkMode": { "type": "string", "description": ":root=light, .dark=dark." },
            "multiBrand": { "type": "string", "description": "[data-brand=\"…\"] composes with .dark." },
            "dataPartConvention": { "type": "string" }
          }
        },
        "rules": {
          "type": "array",
          "description": "Human-readable golden rules mirrored from CONTRACT.md guardrails.",
          "items": { "type": "string" }
        }
      }
    }
  }
}
