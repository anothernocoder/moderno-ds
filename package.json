{
  "name": "moderno-ds",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm --filter @moderno/react typecheck && pnpm --filter @moderno/vue typecheck && pnpm --filter @moderno/solid typecheck && pnpm --filter @moderno/svelte typecheck && pnpm --filter @moderno/docs typecheck",
    "docs:parity": "pnpm --filter @moderno/docs check:parity",
    "test": "vitest run",
    "theme:build": "node --experimental-strip-types tooling/theme-compile/src/bin.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
